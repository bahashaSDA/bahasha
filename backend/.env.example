# Bahasha backend configuration.
#
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored and must never be committed. If a value here is ever
# pasted into a chat, a ticket, or a screenshot, treat it as burned and rotate
# it -- these keys move real money.
#
# src/config/env.ts validates every entry at boot and refuses to start if any
# required value is missing, malformed, or still set to its placeholder below.

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Comma-separated origins permitted to call this API (the treasurer dashboard).
# Must be explicit in production; a wildcard is rejected at boot.
CORS_ORIGINS=http://localhost:3000

# --- Supabase -----------------------------------------------------------------
# Project settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co

# SERVICE ROLE key. Bypasses Row Level Security entirely. Server-side only --
# never ship this to the mobile apps or the dashboard bundle. The dashboard
# uses the ANON key and is constrained by the policies in 0007_rls.sql.
SUPABASE_SERVICE_ROLE_KEY=changeme-service-role-key

# ANON (public) key. Safe to expose; it is constrained by Row Level Security.
# Used for the per-request client that runs dashboard reads under the caller's
# own policies. Optional for BLE/Daraja work; required before dashboard reads.
SUPABASE_ANON_KEY=changeme-anon-public-key

# Project settings -> API -> JWT Settings -> JWT Secret.
# Used to verify dashboard sessions minted by Supabase Auth.
SUPABASE_JWT_SECRET=changeme-jwt-secret-at-least-32-chars

# Project settings -> Database -> Connection string (URI).
# Only used by `npm run db:migrate`; the API itself talks over the Supabase SDK.
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# --- MPESA Daraja -------------------------------------------------------------
# sandbox | production. NODE_ENV=production forces this to production; the app
# refuses to boot if live traffic is pointed at the sandbox.
DARAJA_ENV=sandbox

# developer.safaricom.co.ke -> your app -> Keys
DARAJA_CONSUMER_KEY=changeme-consumer-key
DARAJA_CONSUMER_SECRET=changeme-consumer-secret

# Lipa Na MPESA Online passkey for the shortcode below.
DARAJA_PASSKEY=changeme-passkey

# Business shortcode initiating the STK Push. 174379 is Safaricom's sandbox
# test shortcode; replace with the real paybill before going live.
DARAJA_SHORTCODE=174379

# Public HTTPS URL Safaricom POSTs payment results to. MUST be internet
# reachable -- a localhost value means confirmations silently never arrive and
# every contribution hangs in 'processing'. Use an ngrok/cloudflared tunnel
# locally; use the Render URL in production.
DARAJA_CALLBACK_URL=https://your-service.onrender.com/api/v1/mpesa/callback

# Unguessable segment appended to the callback path. Daraja cannot send custom
# auth headers, so a secret path plus a Safaricom source-IP allowlist is how
# forged callbacks are kept out. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DARAJA_CALLBACK_SECRET=changeme-generate-32-random-bytes-hex

# --- Protocol -----------------------------------------------------------------
# HMAC key used to derive and verify CVendor hub API credentials. Rotating this
# invalidates every hub credential and forces all deacons to re-pair.
# Generate with the same command as above.
HUB_API_KEY_SECRET=changeme-generate-32-random-bytes-hex

# How stale a device-signed BLE payload may be before it is rejected, in
# seconds. Bounds the window in which a captured packet is worth replaying.
# 900 = 15 minutes, which tolerates a hub that lost internet for a while
# without leaving old packets indefinitely valid.
PAYLOAD_MAX_AGE_SECONDS=900

# 32-byte hex key that encrypts each church's MPESA passkey at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_ENCRYPTION_KEY=changeme-generate-32-random-bytes-hex
